# Environment Variables - EXAMPLE FILE
#
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Get Gemini API key: https://aistudio.google.com/app/apikey
# 3. Get Supabase credentials: https://supabase.com/dashboard
# 4. Replace placeholder values with your actual keys
# 5. Save and run: flutter pub get

# Gemini AI API Key (for chatbot + embeddings)
GEMINI_API_KEY=YOUR_API_KEY_HERE

# Supabase Configuration
SUPABASE_URL=YOUR_SUPABASE_URL_HERE
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# Google Sign-In (native iOS/Android)
# 1. In Google Cloud Console > APIs & Services > Credentials, create a Web application OAuth 2.0 client
# 2. Set the same Client ID + Secret in Supabase Dashboard > Auth > Providers > Google
# 3. Paste the Web Client ID below
GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com
